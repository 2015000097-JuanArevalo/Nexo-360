rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function activeUser() {
      return hasProfile() && profile().status == 'active';
    }

    function isTechnical() {
      return activeUser() && profile().accountType == 'technical';
    }

    function isTeacher() {
      return activeUser() && profile().accountType == 'teacher';
    }

    function isStudent() {
      return activeUser() && profile().accountType == 'student';
    }

    function isOrganizer() {
      return activeUser() && profile().eventRole == 'organizer';
    }

    function isActiveStudent(userId) {
      return exists(/databases/$(database)/documents/users/$(userId))
        && get(/databases/$(database)/documents/users/$(userId)).data.accountType == 'student'
        && get(/databases/$(database)/documents/users/$(userId)).data.status == 'active';
    }

    function validAnnouncement(data) {
      return data.keys().hasAll([
          'title', 'message', 'course', 'authorId', 'authorName', 'createdAt'
        ])
        && data.keys().hasOnly([
          'title', 'message', 'course', 'authorId', 'authorName', 'createdAt'
        ])
        && data.title is string
        && data.title.size() >= 3
        && data.title.size() <= 120
        && data.message is string
        && data.message.size() >= 3
        && data.message.size() <= 1000
        && data.course is string
        && data.authorId is string
        && data.authorName is string
        && data.createdAt is timestamp;
    }

    function validActivity(data) {
      return data.keys().hasAll([
          'title', 'description', 'course', 'dueDate', 'teacherId',
          'teacherName', 'createdAt', 'attachmentUrl', 'classId', 'status'
        ])
        && data.keys().hasOnly([
          'title', 'description', 'course', 'dueDate', 'teacherId',
          'teacherName', 'createdAt', 'attachmentUrl', 'classId', 'status'
        ])
        && data.title is string
        && data.title.size() >= 3
        && data.title.size() <= 120
        && data.description is string
        && data.description.size() >= 5
        && data.description.size() <= 3000
        && data.course is string
        && data.dueDate is timestamp
        && data.teacherId is string
        && data.teacherName is string
        && data.createdAt is timestamp
        && (data.attachmentUrl == null || data.attachmentUrl is string)
        && (data.classId == null || data.classId is string)
        && data.status == 'published';
    }

    function validPermission(data) {
      return data.keys().hasAll([
          'studentId', 'studentName', 'classId', 'createdBy', 'reason',
          'destination', 'validFrom', 'validUntil', 'status', 'qrToken',
          'createdAt', 'updatedAt', 'createdFromRequestId'
        ])
        && data.keys().hasOnly([
          'studentId', 'studentName', 'classId', 'createdBy', 'reason',
          'destination', 'validFrom', 'validUntil', 'status', 'qrToken',
          'createdAt', 'updatedAt', 'createdFromRequestId'
        ])
        && data.studentId is string
        && data.studentName is string
        && data.studentName.size() >= 3
        && (data.classId == null || data.classId is string)
        && data.createdBy is string
        && data.reason is string
        && data.reason.size() >= 3
        && data.reason.size() <= 1000
        && data.destination is string
        && data.destination.size() >= 2
        && data.destination.size() <= 300
        && data.validFrom is timestamp
        && data.validUntil is timestamp
        && data.validUntil > data.validFrom
        && data.status in ['active', 'cancelled', 'used', 'expired']
        && data.qrToken is string
        && data.qrToken.size() >= 24
        && data.qrToken.size() <= 128
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (data.createdFromRequestId == null
          || data.createdFromRequestId is string);
    }

    function validPermissionRequest(data) {
      return data.keys().hasAll([
          'requestType', 'targetPermissionId', 'requestedBy',
          'requestDescription', 'status', 'proposedData', 'reviewedBy',
          'reviewComment', 'createdAt', 'updatedAt'
        ])
        && data.keys().hasOnly([
          'requestType', 'targetPermissionId', 'requestedBy',
          'requestDescription', 'status', 'proposedData', 'reviewedBy',
          'reviewComment', 'createdAt', 'updatedAt'
        ])
        && data.requestType in ['create', 'update', 'delete']
        && (data.targetPermissionId == null
          || data.targetPermissionId is string)
        && data.requestedBy is string
        && data.requestDescription is string
        && data.requestDescription.size() >= 3
        && data.status in ['pending', 'approved', 'denied', 'cancelled']
        && data.proposedData is map
        && data.proposedData.studentId is string
        && data.proposedData.studentName is string
        && data.proposedData.reason is string
        && data.proposedData.destination is string
        && data.proposedData.validFrom is timestamp
        && data.proposedData.validUntil is timestamp
        && data.proposedData.validUntil > data.proposedData.validFrom
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function validEvent(data) {
      return data.keys().hasAll([
          'name', 'date', 'location', 'description', 'capacity', 'isPublic',
          'registrationOpen', 'status', 'createdBy', 'createdAt', 'updatedAt'
        ])
        && data.keys().hasOnly([
          'name', 'date', 'location', 'description', 'capacity', 'isPublic',
          'registrationOpen', 'status', 'createdBy', 'createdAt', 'updatedAt'
        ])
        && data.name is string
        && data.name.size() >= 3
        && data.name.size() <= 160
        && data.date is timestamp
        && data.location is string
        && data.location.size() >= 3
        && data.location.size() <= 300
        && data.description is string
        && data.description.size() >= 5
        && data.description.size() <= 3000
        && data.capacity is int
        && data.capacity > 0
        && data.capacity <= 10000
        && data.isPublic is bool
        && data.registrationOpen is bool
        && data.status in ['active', 'cancelled', 'completed']
        && data.createdBy is string
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function validEventRegistration(data) {
      return data.keys().hasAll([
          'eventId', 'fullName', 'email', 'phone', 'organization', 'status',
          'documentUrl', 'createdAt', 'updatedAt', 'checkedIn',
          'checkedInAt', 'checkedInBy'
        ])
        && data.keys().hasOnly([
          'eventId', 'fullName', 'email', 'phone', 'organization', 'status',
          'documentUrl', 'createdAt', 'updatedAt', 'checkedIn',
          'checkedInAt', 'checkedInBy'
        ])
        && data.eventId is string
        && data.fullName is string
        && data.fullName.size() >= 3
        && data.fullName.size() <= 120
        && data.email is string
        && data.email.size() >= 5
        && data.email.size() <= 200
        && data.phone is string
        && data.phone.size() >= 8
        && data.phone.size() <= 40
        && data.organization is string
        && data.organization.size() >= 2
        && data.organization.size() <= 200
        && data.status in ['pending', 'approved', 'reserved', 'rejected']
        && (data.documentUrl == null
          || (data.documentUrl is string && data.documentUrl.size() <= 1000))
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && data.checkedIn is bool
        && (data.checkedInAt == null || data.checkedInAt is timestamp)
        && (data.checkedInBy == null || data.checkedInBy is string)
        && (
          (data.checkedIn == false
            && data.checkedInAt == null
            && data.checkedInBy == null)
          || (data.checkedIn == true
            && data.status == 'approved'
            && data.checkedInAt is timestamp
            && data.checkedInBy is string)
        );
    }

    match /users/{uid} {
      allow get: if activeUser()
        && (request.auth.uid == uid
          || isTechnical()
          || ((isTeacher() || isOrganizer())
            && resource.data.accountType == 'student'));

      // Teacher/organizer queries must filter accountType == 'student'.
      allow list: if isTechnical()
        || ((isTeacher() || isOrganizer())
          && resource.data.accountType == 'student');

      allow create, update, delete: if isTechnical();
    }

    match /school_announcements/{documentId} {
      allow read: if activeUser();
      allow create: if (isTechnical() || isTeacher())
        && validAnnouncement(request.resource.data)
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow update: if (isTechnical()
          || (isTeacher() && resource.data.authorId == request.auth.uid))
        && validAnnouncement(request.resource.data)
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isTechnical()
        || (isTeacher() && resource.data.authorId == request.auth.uid);
    }

    match /school_activities/{documentId} {
      allow read: if activeUser();
      allow create: if (isTechnical() || isTeacher())
        && validActivity(request.resource.data)
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow update: if (isTechnical()
          || (isTeacher() && resource.data.teacherId == request.auth.uid))
        && validActivity(request.resource.data)
        && request.resource.data.teacherId == resource.data.teacherId
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isTechnical()
        || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }

    match /permissions/{permissionId} {
      // QR validation retrieves one permission by its document ID.
      allow get: if isTechnical()
        || isTeacher()
        || (isStudent() && resource.data.studentId == request.auth.uid);

      // Student queries must filter studentId == request.auth.uid.
      allow list: if isTechnical()
        || (isStudent() && resource.data.studentId == request.auth.uid);

      allow create: if isTechnical()
        && validPermission(request.resource.data)
        && isActiveStudent(request.resource.data.studentId)
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if isTechnical()
        && validPermission(request.resource.data)
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.qrToken == resource.data.qrToken
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;

      allow delete: if isTechnical();
    }

    match /permission_requests/{requestId} {
      allow create: if activeUser()
        && (isTeacher() || isOrganizer())
        && validPermissionRequest(request.resource.data)
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.reviewedBy == null
        && request.resource.data.reviewComment == null
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && isActiveStudent(request.resource.data.proposedData.studentId);

      allow read: if isTechnical()
        || (activeUser() && resource.data.requestedBy == request.auth.uid);

      allow update: if isTechnical()
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'targetPermissionId', 'reviewedBy',
          'reviewComment', 'updatedAt'
        ])
        && request.resource.data.status in ['approved', 'denied']
        && request.resource.data.reviewedBy == request.auth.uid
        && request.resource.data.updatedAt == request.time
        && (
          (request.resource.data.status == 'approved'
            && request.resource.data.targetPermissionId is string
            && existsAfter(
              /databases/$(database)/documents/permissions/$(request.resource.data.targetPermissionId)
            ))
          || (request.resource.data.status == 'denied'
            && request.resource.data.targetPermissionId == null)
        );

      allow delete: if isTechnical();
    }

    match /events/{eventId} {
      allow read: if resource.data.isPublic == true || activeUser();

      allow create: if (isTechnical() || isOrganizer())
        && validEvent(request.resource.data)
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if (isTechnical() || isOrganizer())
        && validEvent(request.resource.data)
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;

      allow delete: if isTechnical() || isOrganizer();
    }

    match /event_registrations/{registrationId} {
      allow create: if validEventRegistration(request.resource.data)
        && request.resource.data.status == 'pending'
        && request.resource.data.checkedIn == false
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && exists(
          /databases/$(database)/documents/events/$(request.resource.data.eventId)
        )
        && get(
          /databases/$(database)/documents/events/$(request.resource.data.eventId)
        ).data.isPublic == true
        && get(
          /databases/$(database)/documents/events/$(request.resource.data.eventId)
        ).data.registrationOpen == true
        && get(
          /databases/$(database)/documents/events/$(request.resource.data.eventId)
        ).data.status == 'active';

      // A random document ID is the public tracking code for this prototype.
      allow get: if true;
      allow list: if isTechnical() || isOrganizer();

      allow update: if (isTechnical() || isOrganizer())
        && validEventRegistration(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'updatedAt', 'checkedIn', 'checkedInAt', 'checkedInBy'
        ])
        && request.resource.data.updatedAt == request.time
        && (resource.data.checkedIn == false
          || request.resource.data.checkedIn == true)
        && (request.resource.data.checkedIn == false
          || request.resource.data.checkedInBy == request.auth.uid);

      allow delete: if isTechnical();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
